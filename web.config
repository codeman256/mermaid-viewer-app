<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- server.js already serves static files from /public and handles
             all /api/* routes itself, so every request can go through it. -->
        <rule name="AllRequestsToServerJs">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode
      watchedFiles="web.config;server.js"
      loggingEnabled="true"
      devErrorsEnabled="false" />
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
