# Copy this file to `.env` (gitignored) and fill in your real values.
# docker-compose.yml reads `.env` automatically.

# Leave blank to run with this app's own bundled example-diagrams/ instead —
# handy for a first look before you have a real diagrams repo ready. Point it
# at your own repo (e.g. https://github.com/your-org/your-diagrams-repo.git)
# once you do.
GIT_REPO_URL=
DIAGRAMS_SUBDIR=diagrams
GIT_PULL_INTERVAL_MINUTES=5

# Optional — only needed behind a reverse proxy under a different public
# hostname than the one Node sees. Leave unset otherwise.
PUBLIC_BASE_URL=
