classDiagram
    class Animal {
        +String name
        +int age
        +makeSound() void
    }
    class Dog {
        +String breed
        +fetch() void
    }
    class Cat {
        +bool indoor
        +scratch() void
    }
    class Shelter {
        +List~Animal~ animals
        +admit(Animal a) void
        +adopt(Animal a) void
    }

    Animal <|-- Dog
    Animal <|-- Cat
    Shelter "1" o-- "*" Animal : houses
